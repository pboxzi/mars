DB_NAME=bruno_mars_vip
MONGO_URL=mongodb+srv://<username>:<password>@<cluster-url>/bruno_mars_vip?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=https://your-frontend-url.vercel.app
CORS_ORIGINS=https://your-frontend-url.vercel.app

DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SETUP_KEY=replace-with-a-one-time-seed-key

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
SENDER_EMAIL=bookings@yourdomain.com
ADMIN_EMAIL=you@yourdomain.com

SUPPORT_EMAIL=bookings@yourdomain.com
SUPPORT_PHONE=
SUPPORT_WHATSAPP=
SUPPORT_INSTAGRAM=
SUPPORT_HOURS=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_GRAPH_VERSION=v23.0

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Set to 1 only if you need remoteip sent to Turnstile siteverify (default off avoids proxy IP mismatches).
TURNSTILE_INCLUDE_REMOTEIP=
# Emergency only: skips Turnstile siteverify (bots can submit). Remove after keys are fixed.
DISABLE_TURNSTILE_VERIFICATION=
BOOKING_RATE_LIMIT=5
BOOKING_RATE_LIMIT_WINDOW_SECONDS=900
SUBSCRIPTION_RATE_LIMIT=6
SUBSCRIPTION_RATE_LIMIT_WINDOW_SECONDS=900
PAYMENT_UPDATE_RATE_LIMIT=6
PAYMENT_UPDATE_RATE_LIMIT_WINDOW_SECONDS=900
